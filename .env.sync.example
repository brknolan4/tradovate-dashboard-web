# Tradovate sync sidecar local environment
# Recommended: copy this to sync-sidecar/.env.sync.local.
# That file is ignored by git and intended for local-only secrets.
# Do NOT commit real credentials.

# Deterministic fallback only.
# Preferred path is the sidecar's own persistent profile under sync-sidecar/runtime/dedicated-browser-profile.
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=

# Optional. Not used automatically yet, but reserved for future MFA/TOTP handling.
TRADOVATE_TOTP_SECRET=

# Browser/session configuration
TRADOVATE_LOGIN_URL=https://trader.tradovate.com/
TRADOVATE_REPORTS_BASE_URL=https://trader.tradovate.com/
TRADOVATE_SYNC_BROWSER_CHANNEL=
TRADOVATE_SYNC_BROWSER_EXECUTABLE_PATH=
TRADOVATE_SYNC_BROWSER_TIMEOUT_MS=30000
TRADOVATE_SYNC_POST_LOGIN_WAIT_MS=4000
TRADOVATE_SYNC_DOWNLOAD_TIMEOUT_MS=45000
TRADOVATE_SYNC_BOOTSTRAP_ONLY=false
TRADOVATE_SYNC_MANUAL_LOGIN=false
TRADOVATE_SYNC_MANUAL_LOGIN_TIMEOUT_MS=900000
TRADOVATE_SYNC_MANUAL_LOGIN_POLL_MS=2000
TRADOVATE_SYNC_NON_INTERACTIVE=false

# Sidecar behavior
# Leave this at the default dedicated path unless you intentionally want another sidecar-owned profile.
TRADOVATE_SYNC_DOWNLOAD_DIR=./runtime/downloads
TRADOVATE_SYNC_SESSION_DIR=./runtime/dedicated-browser-profile
TRADOVATE_SYNC_PROFILE_DIR=Default
TRADOVATE_SYNC_IMPORT_STAGING_DIR=./runtime/staging
TRADOVATE_SYNC_HEADLESS=false
